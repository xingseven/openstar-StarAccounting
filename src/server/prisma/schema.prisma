generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 用户主表：账号信息与所有业务数据的归属主体
model User {
  id           String          @id @default(cuid())
  email        String          @unique
  password     String
  name         String?
  transactions Transaction[]
  loans        Loan[]
  savingsGoals SavingsGoal[]
  assets       Asset[]
  budgets      Budget[]
  settings     ThemeConfig?
  connections  AppConnection[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

/// 汇率表：维护币种兑换比率（from -> to）
model ExchangeRate {
  id        String   @id @default(cuid())
  from      String
  to        String
  rate      Decimal
  updatedAt DateTime @updatedAt

  @@unique([from, to])
}

/// 设备连接验证表：用于多端绑定、OTP 校验与设备追踪
model AppConnection {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String?
  deviceName String?
  ipAddress  String?
  otpCode    String
  isVerified Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  verifiedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([otpCode])
  @@index([userId, isVerified])
  @@unique([otpCode, isVerified])
}

/// 交易流水表：收入/支出/转账/还款记录
model Transaction {
  id            String          @id @default(cuid())
  userId        String
  amount        Decimal
  type          TransactionType
  category      String
  platform      String
  merchant      String?
  date          DateTime
  description   String?
  orderId       String?         @unique
  paymentMethod String?
  status        String?

  loanId String?
  loan   Loan? @relation(fields: [loanId], references: [id])

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, loanId])
}

/// 贷款主表：记录每笔贷款及其还款进度
model Loan {
  id              String      @id @default(cuid())
  userId          String
  platform        String
  totalAmount     Decimal
  remainingAmount Decimal
  periods         Int
  paidPeriods     Int
  monthlyPayment  Decimal
  dueDate         Int
  status          LoanStatus  @default(ACTIVE)
  matchKeywords   Json?
  transactions    Transaction[]

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

/// 储蓄目标表：定义储蓄目标及目标级配置
model SavingsGoal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal
  currentAmount Decimal    @default(0)
  deadline      DateTime?
  type          GoalType   @default(LONG_TERM)
  depositType   DepositType @default(CASH)
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  plans SavingsPlan[]
  /// 计划配置快照（示例：{ salary, expenseDefs, depositDay, duration }）
  planConfig Json?
  user User @relation(fields: [userId], references: [id])
}

/// 储蓄计划明细表：按月存储计划数据，可支持动态支出列
model SavingsPlan {
  id        String   @id @default(cuid())
  goalId    String
  amount    Decimal
  status    PlanStatus @default(PENDING)
  /// 计划月份，格式：YYYY-MM
  month     String
  
  /// 扩展字段：用于隔月存/高级模式
  salary    Decimal? @default(0)
  /// 动态支出列 JSON（示例：{ "房租": 2000, "水电": 300 }）
  expenses  Json?
  remark    String?
  /// 打卡凭证图片（Data URL 或可访问 URL）
  proofImage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

/// 主题配置表：存储用户的界面主题与图表样式偏好
model ThemeConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  themeId      String   @default("default")
  primaryColor String?
  radius       Float?
  isDarkMode   Boolean  @default(false)
  chartStyle   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

/// 资产账户表：现金、银行卡、支付平台与投资账户余额
model Asset {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AssetType
  balance   Decimal     @default(0)
  currency  String      @default("CNY")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

/// 预算表：按周期与分类记录预算额度
model Budget {
  id        String       @id @default(cuid())
  userId    String
  amount    Decimal
  category  String       @default("ALL") // "ALL" for total budget, or specific category name
  period    BudgetPeriod @default(MONTHLY)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, category, period])
}

/// 预算周期枚举
enum BudgetPeriod {
  MONTHLY
  YEARLY
}

/// 资产类型枚举
enum AssetType {
  CASH
  BANK_CARD
  ALIPAY
  WECHAT
  INVESTMENT
  OTHER
}

/// 交易类型枚举
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  REPAYMENT
}

/// 贷款状态枚举
enum LoanStatus {
  ACTIVE
  PAID_OFF
  OVERDUE
}

/// 储蓄目标类型枚举
enum GoalType {
  MONTHLY
  YEARLY
  LONG_TERM
  BI_MONTHLY_ODD
  BI_MONTHLY_EVEN
}

/// 存款来源/性质枚举
enum DepositType {
  CASH
  FIXED_TERM
  HELP_DEPOSIT
}

/// 储蓄目标状态枚举
enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// 储蓄计划状态枚举
enum PlanStatus {
  PENDING
  COMPLETED
  SKIPPED
}
