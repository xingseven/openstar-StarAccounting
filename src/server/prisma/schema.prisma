generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  password     String
  name         String?
  transactions Transaction[]
  loans        Loan[]
  savingsGoals SavingsGoal[]
  assets       Asset[]
  budgets      Budget[]
  settings     ThemeConfig?
  connections  AppConnection[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  from      String
  to        String
  rate      Decimal
  updatedAt DateTime @updatedAt

  @@unique([from, to])
}

model AppConnection {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String?
  deviceName String?
  ipAddress  String?
  otpCode    String
  isVerified Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  verifiedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([otpCode])
  @@index([userId, isVerified])
  @@unique([otpCode, isVerified])
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  amount        Decimal
  type          TransactionType
  category      String
  platform      String
  merchant      String?
  date          DateTime
  description   String?
  orderId       String?         @unique
  paymentMethod String?
  status        String?

  loanId String?
  loan   Loan? @relation(fields: [loanId], references: [id])

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, loanId])
}

model Loan {
  id              String      @id @default(cuid())
  userId          String
  platform        String
  totalAmount     Decimal
  remainingAmount Decimal
  periods         Int
  paidPeriods     Int
  monthlyPayment  Decimal
  dueDate         Int
  status          LoanStatus  @default(ACTIVE)
  matchKeywords   Json?
  transactions    Transaction[]

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model SavingsGoal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal
  currentAmount Decimal    @default(0)
  deadline      DateTime?
  type          GoalType   @default(LONG_TERM)
  depositType   DepositType @default(CASH)
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ThemeConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  themeId      String   @default("default")
  primaryColor String?
  radius       Float?
  isDarkMode   Boolean  @default(false)
  chartStyle   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Asset {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AssetType
  balance   Decimal     @default(0)
  currency  String      @default("CNY")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model Budget {
  id        String       @id @default(cuid())
  userId    String
  amount    Decimal
  category  String       @default("ALL") // "ALL" for total budget, or specific category name
  period    BudgetPeriod @default(MONTHLY)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, category, period])
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
}

enum AssetType {
  CASH
  BANK_CARD
  ALIPAY
  WECHAT
  INVESTMENT
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  REPAYMENT
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
  OVERDUE
}

enum GoalType {
  MONTHLY
  YEARLY
  LONG_TERM
  BI_MONTHLY_ODD
  BI_MONTHLY_EVEN
}

enum DepositType {
  CASH
  FIXED_TERM
  HELP_DEPOSIT
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}
