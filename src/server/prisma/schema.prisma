generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aimodelconfig {
  id          String   @id
  userId      String
  name        String
  provider    String
  type        String   @default("vision")
  apiKey      String?
  endpoint    String?
  modelId     String?
  description String?
  status      String   @default("inactive")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "aimodelconfig_ibfk_1")

  @@index([userId], map: "AIModelConfig_userId_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appconnection {
  id         String    @id
  userId     String
  deviceId   String?
  deviceName String?
  ipAddress  String?
  otpCode    String
  isVerified Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  verifiedAt DateTime?
  user       user      @relation(fields: [userId], references: [id], map: "AppConnection_userId_fkey")

  @@unique([otpCode, isVerified], map: "AppConnection_otpCode_isVerified_key")
  @@index([otpCode], map: "AppConnection_otpCode_idx")
  @@index([userId, isVerified], map: "AppConnection_userId_isVerified_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asset {
  id        String     @id
  userId    String
  name      String
  type      asset_type
  balance   Decimal    @default(0.000000000000000000000000000000)
  currency  String     @default("CNY")
  createdAt DateTime   @default(now())
  updatedAt DateTime
  user      user       @relation(fields: [userId], references: [id], map: "Asset_userId_fkey")

  @@index([userId, type], map: "Asset_userId_type_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model budget {
  id           String           @id
  userId       String
  amount       Decimal
  category     String           @default("ALL")
  period       budget_period    @default(MONTHLY)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime
  alertPercent Int              @default(80)
  platform     String?
  scopeType    budget_scopeType @default(GLOBAL)

  @@unique([userId, category, period, scopeType, platform], map: "Budget_userId_category_period_scopeType_platform_key")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model exchangerate {
  id        String   @id
  from      String
  to        String
  rate      Decimal
  updatedAt DateTime

  @@unique([from, to], map: "ExchangeRate_from_to_key")
}

model importerrorlog {
  id           String   @id
  userId       String
  fileName     String
  lineNumber   Int
  rawData      String   @db.Text
  errorMessage String   @db.Text
  errorType    String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId], map: "ImportErrorLog_userId_idx")
  @@index([userId, resolved], map: "ImportErrorLog_userId_resolved_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model loan {
  id              String        @id
  userId          String
  platform        String
  totalAmount     Decimal
  remainingAmount Decimal
  periods         Int
  paidPeriods     Int
  monthlyPayment  Decimal
  dueDate         Int
  status          loan_status   @default(ACTIVE)
  matchKeywords   Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  user            user          @relation(fields: [userId], references: [id], map: "Loan_userId_fkey")
  transaction     transaction[]

  @@index([userId, status], map: "Loan_userId_status_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model savingsgoal {
  id            String                  @id
  userId        String
  name          String
  targetAmount  Decimal
  currentAmount Decimal                 @default(0.000000000000000000000000000000)
  deadline      DateTime?
  type          savingsgoal_type        @default(LONG_TERM)
  status        savingsgoal_status      @default(ACTIVE)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime
  depositType   savingsgoal_depositType @default(CASH)
  planConfig    Json?
  user          user                    @relation(fields: [userId], references: [id], map: "SavingsGoal_userId_fkey")
  savingsplan   savingsplan[]

  @@index([userId], map: "SavingsGoal_userId_fkey")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model savingsplan {
  id          String             @id
  goalId      String
  amount      Decimal
  status      savingsplan_status @default(PENDING)
  month       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime
  expenses    Json?
  remark      String?
  salary      Decimal?           @default(0.000000000000000000000000000000)
  proofImage  String?            @db.Text
  savingsgoal savingsgoal        @relation(fields: [goalId], references: [id], onDelete: Cascade, map: "SavingsPlan_goalId_fkey")

  @@index([goalId], map: "SavingsPlan_goalId_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model themeconfig {
  id           String   @id
  userId       String   @unique(map: "ThemeConfig_userId_key")
  themeId      String   @default("default")
  primaryColor String?
  radius       Float?
  isDarkMode   Boolean  @default(false)
  chartStyle   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  user         user     @relation(fields: [userId], references: [id], map: "ThemeConfig_userId_fkey")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model transaction {
  id            String           @id
  userId        String
  amount        Decimal
  type          transaction_type
  category      String
  platform      String
  merchant      String?
  date          DateTime
  description   String?
  orderId       String?          @unique(map: "Transaction_orderId_key")
  paymentMethod String?
  status        String?
  loanId        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime
  loan          loan?            @relation(fields: [loanId], references: [id], map: "Transaction_loanId_fkey")
  user          user             @relation(fields: [userId], references: [id], map: "Transaction_userId_fkey")

  @@index([loanId], map: "Transaction_loanId_fkey")
  @@index([userId, date], map: "Transaction_userId_date_idx")
  @@index([userId, loanId], map: "Transaction_userId_loanId_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user {
  id            String          @id
  email         String          @unique(map: "User_email_key")
  password      String
  name          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  role          user_role       @default(USER)
  aimodelconfig aimodelconfig[]
  appconnection appconnection[]
  asset         asset[]
  loan          loan[]
  savingsgoal   savingsgoal[]
  themeconfig   themeconfig?
  transaction   transaction[]
}

enum asset_type {
  CASH
  BANK_CARD
  ALIPAY
  WECHAT
  INVESTMENT
  OTHER
}

enum savingsplan_status {
  PENDING
  COMPLETED
  SKIPPED
}

enum transaction_type {
  INCOME
  EXPENSE
  TRANSFER
  REPAYMENT
}

enum budget_period {
  MONTHLY
  YEARLY
}

enum savingsgoal_type {
  MONTHLY
  YEARLY
  LONG_TERM
  BI_MONTHLY_ODD
  BI_MONTHLY_EVEN
}

enum user_role {
  USER
  ADMIN
}

enum savingsgoal_status {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum budget_scopeType {
  GLOBAL
  CATEGORY
  PLATFORM
}

enum loan_status {
  ACTIVE
  PAID_OFF
  OVERDUE
}

enum savingsgoal_depositType {
  CASH
  FIXED_TERM
  HELP_DEPOSIT
}
