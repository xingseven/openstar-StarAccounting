{
  "name": "openstar-staraccounting-web",
  "version": "2.3.74",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "cd web && next dev -H 0.0.0.0 -p 3000",
    "dev:server": "cd server && npm run dev",
    "dev:legacy": "concurrently -n backend,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "build": "cd web && npm run build",
    "start": "cd web && next start",
    "lint": "cd web && eslint",
    "typecheck": "cd web && tsc --noEmit",
    "test:e2e": "cd web && playwright test",
    "test:e2e:ui": "cd web && playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.87.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^10.0.3",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.6",
    "simple-icons": "^16.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
