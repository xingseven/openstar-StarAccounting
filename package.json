  "bugs": {
    "url": "https://github.com/xingseven/openstar-xfdashborad/issues"
  },
  "homepage": "https://github.com/xingseven/openstar-xfdashborad#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "mysql2": "^3.19.1",
    "xlsx": "^0.18.5"
  }
}
